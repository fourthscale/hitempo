# Supabase (local: filled by `supabase status`; prod: from Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_POSTGRES_URL=            # pooled connection (runtime queries via Drizzle)
SUPABASE_POSTGRES_DIRECT_URL=     # direct connection (drizzle-kit, server-only)
# Per-instance pool tuning. Defaults baked in code are sized for the
# Supabase free-tier session pooler (15-slot global cap, IPv4-only). Override
# these when on a Pro / IPv4 transaction-pooler setup with a generous pool
# (then ~10/5/60 works well — get back parallel queries on dashboard-style
# pages without saturating). Leave blank to inherit the code default.
# Defaults : RLS=3 / ADMIN=2 / IDLE_TIMEOUT=20s
SUPABASE_POSTGRES_POOL_MAX_RLS=
SUPABASE_POSTGRES_POOL_MAX_ADMIN=
SUPABASE_POSTGRES_POOL_IDLE_TIMEOUT_SEC=

# Site URL (used to build OAuth/password-reset redirect URIs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email) — set later, ok to leave blank for sprint 01
RESEND_API_KEY=

# AI — LLM provider selection (sprint 07)
# LLM_PROVIDER picks the active strategy at runtime.
# Only the credentials for the active provider are required at boot.
# Supported values: openai | anthropic
LLM_PROVIDER=openai

# OpenAI (MVP default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Anthropic (ready, optional — leave blank unless LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Mistral (V1+)
MISTRAL_API_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Inngest (set in sprint 08)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1 (1 for dev local, 0 or nothing for prod)

#Google Gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_TOKEN_ENCRYPTION_KEY=

#Microsoft Azure Mail
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_REDIRECT_URI=https://hitempo.vercel.app/api/auth/mail/callback